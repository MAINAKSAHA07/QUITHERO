# Copy to .env and fill in values (never commit .env)

# PocketBase — local dev
VITE_POCKETBASE_URL=http://localhost:8096
PB_ADMIN_EMAIL=
# PocketBase admin password — min 10 chars, never commit real value
PB_ADMIN_PASSWORD=change-this-immediately

# PocketBase — production / EC2 deploy
AWS_POCKETBASE_URL=http://YOUR_EC2_IP:8096
AWS_PB_ADMIN_EMAIL=
AWS_PB_ADMIN_PASSWORD=

# Google OAuth (create a Smono Web client — do not reuse n8n credentials)
VITE_GOOGLE_CLIENT_ID=
# Google Client Secret — SERVER SIDE ONLY. Never use VITE_ prefix.
GOOGLE_CLIENT_SECRET=

# Claude API — SERVER SIDE ONLY. Never use VITE_ prefix.
ANTHROPIC_API_KEY=your-anthropic-key-here

# Web Push (server) — run: npm run generate-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@smono.app

# EC2 API server — PocketBase on same host (used by push scheduler)
POCKETBASE_INTERNAL_URL=http://127.0.0.1:8096

# Support chat AES-256-GCM (32-byte hex). Server-only — never use VITE_ prefix.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SUPPORT_CHAT_KEY=

# AI Proxy URL — safe to expose, points to your own backend
VITE_AI_PROXY_URL=/api/ai/personalize

# Public app URL (OAuth redirect URI — must be the user app origin, not the marketing site)
# PUBLIC_URL=https://app.smono.app

# Marketing domain split (landing @ root, app @ app.*, admin @ admin.*)
DOMAIN_ROOT=smono.app

# EC2 remote deploy (optional — deploy.sh auto-detects quithero.pem)
# EC2_HOST=ec2-user@YOUR_EC2_IP
# EC2_SSH_KEY=./quithero.pem
