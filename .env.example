# Copy to .env and fill in values (never commit .env)

# PocketBase — local dev
VITE_POCKETBASE_URL=http://localhost:8096
PB_ADMIN_EMAIL=
PB_ADMIN_PASSWORD=

# PocketBase — production / EC2 deploy
AWS_POCKETBASE_URL=http://YOUR_EC2_IP:8096
AWS_PB_ADMIN_EMAIL=
AWS_PB_ADMIN_PASSWORD=

# Google OAuth (create a Quit Hero Web client — do not reuse n8n credentials)
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_SECRET=

# Public frontend URL (used by configure-oauth.js for redirect URI hints)
# PUBLIC_URL=https://quithero.netlify.app

# EC2 remote deploy (optional — deploy.sh auto-detects quithero.pem)
# EC2_HOST=ec2-user@YOUR_EC2_IP
# EC2_SSH_KEY=./quithero.pem
