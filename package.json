{
  "name": "quit-hero",
  "version": "1.0.0",
  "description": "Smono - Quit smoking recovery app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "postbuild": "node scripts/write-netlify-redirects.js",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "pb:start": "docker-compose up -d",
    "pb:stop": "docker-compose down",
    "pb:logs": "docker-compose logs -f pocketbase",
    "pb:restart": "docker-compose restart pocketbase",
    "pb:complete-setup": "node PocketBase/complete-setup.js",
    "pb:setup": "node PocketBase/setup-pocketbase.js",
    "pb:rules": "node PocketBase/set-rules.js",
    "pb:fix-sessions": "node PocketBase/fix-user-sessions.js",
    "pb:fix-cravings": "node PocketBase/fix-cravings-collection.js",
    "pb:seed-program": "node PocketBase/seed-full-program.js",
    "pb:migrate-rag": "node PocketBase/migrate-content-rag.js",
    "pb:seed-day": "node PocketBase/seed-program-day.js",
    "pb:seed-all-days": "node PocketBase/seed-all-program-days.js",
    "pb:import-docs": "node PocketBase/import-program-docs.js",
    "pb:setup-behavior": "node PocketBase/setup-behavior-collections.js",
    "pb:setup-ai-memory": "node PocketBase/setup-ai-memory.js",
    "pb:verify-backoffice": "node PocketBase/verify-backoffice.js",
    "pb:reset-backoffice-admin": "node PocketBase/reset-backoffice-admin.js",
    "pb:add-last-active": "node PocketBase/add-last-active.js",
    "pb:fix-last-active": "node PocketBase/fix-last-active.js",
    "pb:add-timezone": "node PocketBase/add-timezone-field.js",
    "pb:add-phone": "node PocketBase/add-phone-field.js",
    "pb:seed-sample": "node PocketBase/seed-sample.js",
    "dev:backoffice": "cd backoffice && npm run dev",
    "dev:landing": "cd landing && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:backoffice\" \"npm run dev:landing\"",
    "ai-proxy": "node scripts/api-server.js",
    "api-server": "node scripts/api-server.js",
    "generate-vapid": "node scripts/generate-vapid-keys.js",
    "pb:setup-push": "node PocketBase/setup-push-collections.js",
    "pb:setup-smoke-check": "node PocketBase/setup-smoke-check.js",
    "pb:setup-account-deletion": "node PocketBase/setup-account-deletion.js",
    "pb:setup-blog-fields": "node PocketBase/setup-blog-fields.js",
    "pb:setup-media": "node PocketBase/setup-media.js",
    "pb:setup-app-settings": "node PocketBase/setup-app-settings.js",
    "pb:setup-notification-prefs": "node PocketBase/setup-notification-prefs.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@tanstack/react-query": "^5.90.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^10.16.16",
    "lucide-react": "^0.294.0",
    "pocketbase": "^0.26.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.15.4",
    "tailwind-merge": "^3.6.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  }
}
